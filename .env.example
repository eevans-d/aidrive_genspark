# Supabase Configuration
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Frontend (Vite)
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_API_GATEWAY_URL=http://localhost:54321/functions/v1/api-minimarket
# AI Assistant URL (optional — defaults to VITE_SUPABASE_URL/functions/v1/api-assistant)
VITE_API_ASSISTANT_URL=http://localhost:54321/functions/v1/api-assistant
# Optional client-side session guards (defaults: 24h timebox, 8h inactivity timeout)
VITE_AUTH_TIMEBOX_MS=86400000
VITE_AUTH_INACTIVITY_TIMEOUT_MS=28800000
VITE_USE_MOCKS=true
# Optional (only if a real DSN exists; do not log the value):
VITE_SENTRY_DSN=
# Optional build metadata (injected by CI)
VITE_BUILD_ID=dev

# CI/CD Configuration
# Used by GitHub Actions scripts and verify-deploy
PROJECT_ID=your-project-id
ACCESS_TOKEN=your-access-token
DB_PASSWORD=your-db-password

# Edge Function Secrets (set in Supabase, values never committed)
API_PROVEEDOR_SECRET=your-shared-secret
# OCR provider secret (required when facturas-ocr is in scope)
GCV_API_KEY=your-google-cloud-vision-key
# OCR confidence threshold for /facturas/{id}/aplicar guard (0..1, default 0.70)
OCR_MIN_SCORE_APPLY=0.70
# Optional read mode (recommended: anon)
API_PROVEEDOR_READ_MODE=anon
# Optional read mode for scraper (recommended: anon)
SCRAPER_READ_MODE=anon
SENDGRID_API_KEY=your-sendgrid-api-key
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key
SMTP_FROM=noreply@example.com
# Optional alias (legacy compatibility):
EMAIL_FROM=noreply@example.com
# Optional webhook channels
WEBHOOK_URL=
SLACK_WEBHOOK_URL=
# Optional SMS channels (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Application Settings
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Optional internal origin allowlist extension (comma-separated)
INTERNAL_ORIGINS_ALLOWLIST=
REQUIRE_ORIGIN=true
NOTIFICATIONS_MODE=simulation
ENVIRONMENT=development
LOG_LEVEL=info
TEST_ENVIRONMENT=development

# Optional smoke/perf script credentials (non-production)
TEST_USER_ADMIN=admin@example.test
TEST_PASSWORD=change-me

# Operational smoke check (scripts/ops-smoke-check.mjs)
OPS_SMOKE_TARGET=local
OPS_SMOKE_TIMEOUT_MS=6000
OPS_SMOKE_RETRIES=1
OPS_SMOKE_RETRY_DELAY_MS=800
# Optional endpoint base overrides
OPS_SMOKE_BASE_URL=
OPS_SMOKE_LOCAL_BASE_URL=http://127.0.0.1:54321/functions/v1
OPS_SMOKE_REMOTE_BASE_URL=
# Optional auth headers for protected checks
OPS_SMOKE_SERVICE_ROLE_KEY=
OPS_SMOKE_API_PROVEEDOR_SECRET=
OPS_SMOKE_API_PROVEEDOR_AUTHORIZATION=
OPS_SMOKE_AUTHORIZATION=
