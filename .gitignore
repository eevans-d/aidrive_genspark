# ==============================================================================
# .gitignore — aidrive_genspark (Node/TS + Deno + Supabase + Python scripts)
# ==============================================================================

# ── Local / Scratch ──────────────────────────────────────────────────────────
Nueva carpeta/
*:Zone.Identifier
**/*:Zone.Identifier
**/*Zone.Identifier

# ── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
minimarket-system/node_modules/
.npm/
.pnpm-store/

# ── Lockfiles (ignore generic, allow repo-level) ────────────────────────────
**/package-lock.json
**/pnpm-lock.yaml
!package-lock.json
!minimarket-system/pnpm-lock.yaml

# ── Build / Coverage artifacts ───────────────────────────────────────────────
coverage/
minimarket-system/dist/
minimarket-system/coverage/
*.tsbuildinfo

# ── Logs & temp files ────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
tmp/
temp/

# ── Test reports (local artifacts) ───────────────────────────────────────────
test-reports/
**/test-reports/
**/test-results/
test_report_*.json
test_output.txt
report_record.txt

# ── Environment / Secrets ────────────────────────────────────────────────────
.env
.env.*
!.env.example
!.env.template
!.env.test.example
.env.local
*.pem
*.key
*.p12
*.pfx
*.jks
*.keystore
secrets/
credentials/
.secrets/
.credentials/
auth.json
service-account*.json
.gcloud/
.aws/
.azure/

# ── Python (used by .agent/ scripts) ────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
.mypy_cache/
.pytest_cache/
.venv/
venv/

# ── IDE / Editor ─────────────────────────────────────────────────────────────
# Allow root .vscode (contains workspace performance settings)
.vscode/
!/.vscode/
!/.vscode/settings.json

.cursor/
.idea/
*.sublime-workspace
*.sublime-project
*.swp
*.swo
*~
.history/

# ── OS files ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
*.stackdump

# ── Cache ────────────────────────────────────────────────────────────────────
.cache/
.parcel-cache/
.eslintcache
.stylelintcache

# ── Backup / Archive ────────────────────────────────────────────────────────
*.bak
*.backup
*.old
*.orig
*.rej
*.tmp
*.temp

# ── Compressed archives ─────────────────────────────────────────────────────
*.zip
*.rar
*.7z
*.tar
*.gz
*.tgz
*.tar.gz
*.tar.bz2
*.tar.xz

# ── Deno ─────────────────────────────────────────────────────────────────────
# deno.lock is tracked for reproducibility

# ── Database dumps ───────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
dump.rdb
*.sql
!supabase/migrations/*.sql
!supabase/cron_jobs/*.sql
!scripts/*.sql

# ==============================================================================
# PROJECT SPECIFIC — MINI MARKET INVENTORY
# ==============================================================================

# Browser automation artifacts
.browser_screenshots/
browser/screenshots/
browser/user_data/

# Allow frontend E2E scaffolding
!minimarket-system/e2e/
!minimarket-system/e2e/**

# Allow frontend lib sources
!minimarket-system/src/lib/
!minimarket-system/src/lib/**

# Agent memory/state
.memory/
memory/
shell_output_save/
user_input_files/

# Deploy backups
backups/

# Legacy/deprecated artifacts
deploy_url.txt
workspace.json
_archive/
archive/
!docs/archive/
!docs/archive/**
!docs/closure/archive/
docs/closure/archive/*
!docs/closure/archive/INDEX.md
!docs/closure/archive/historical/
docs/closure/archive/historical/*
!docs/closure/archive/historical/BASELINE_LOG_2026-03-12_033328.md
!docs/closure/archive/historical/INVENTORY_REPORT_2026-03-12_033859.md
!docs/closure/archive/historical/TECHNICAL_ANALYSIS_2026-03-12_033857.md
!docs/closure/archive/historical/MEGA_PLAN_2026-03-12_045452.md

# Session reports (use CHANGELOG.md instead)
REPORTE_*.md
!docs/REPORTE_ANALISIS_PROYECTO.md
!docs/closure/REPORTE_AUDITORIA_PREPRODUCCION_DEFINITIVO_2026-02-16.md
!docs/closure/REPORTE_AUDITORIA_SRE_DEFINITIVO_2026-02-17.md
!docs/closure/REPORTE_AUDITORIA_PLAN_FRONTEND_UX_2026-02-19.md
!docs/closure/REPORTE_EJECUCION_DOCUMENTAL_PRODUCCION_*.md
!docs/closure/REPORTE_CIERRE_EXHAUSTIVO_D153_2026-02-22.md
!docs/closure/REPORTE_AFINAMIENTO_PREPRODUCCION_CLAUDE_2026-02-22.md
!docs/closure/REPORTE_CIERRE_FINAL_*.md
!docs/closure/REPORTE_CONTINUIDAD_GO_LIVE_*.md
SINCRONIZACION_*.md
GIT_SYNC_STATUS.md
test-progress*.md
testing_reporte_*.md

# Allow closure audit .ini tracking
!docs/closure/*.ini

# Local ad-hoc artifacts (not repo deliverables)
product_catalog_final_updated (1).pdf

# Temporary invoice/supplier images (user data, not repo content)
proveedores_facturas_temp/
