{
  "version": 1,
  "scope": "Supabase Edge Function runtime and backend-oriented env vars audited by .agent/scripts/env_audit.py --with-supabase",
  "variables": {
    "ALLOWED_ORIGINS": {
      "supabase": { "dev": "optional", "staging": "required", "prod": "required" },
      "notes": "CORS allowlist. Local dev has safe defaults; staging/prod should set explicit origins."
    },
    "API_PROVEEDOR_READ_MODE": {
      "supabase": { "dev": "optional", "staging": "optional", "prod": "optional" },
      "notes": "Defaults to anon when unset."
    },
    "API_PROVEEDOR_SECRET": {
      "supabase": { "dev": "optional", "staging": "required", "prod": "required" },
      "notes": "Required for protected write paths and operational smoke in non-local environments."
    },
    "EMAIL_FROM": {
      "supabase": { "dev": "optional", "staging": "optional", "prod": "optional" },
      "notes": "Legacy alias. SMTP_FROM remains the primary source when email notifications are enabled."
    },
    "ENVIRONMENT": {
      "supabase": { "dev": "optional", "staging": "optional", "prod": "optional" },
      "notes": "Falls back to deployment context when unset."
    },
    "GCV_API_KEY": {
      "supabase": { "dev": "optional", "staging": "required", "prod": "required" },
      "notes": "Required only while OCR over Google Cloud Vision remains in scope."
    },
    "INTERNAL_ORIGINS_ALLOWLIST": {
      "supabase": { "dev": "optional", "staging": "optional", "prod": "optional" },
      "notes": "Optional extension for internal-only origins."
    },
    "LOG_LEVEL": {
      "supabase": { "dev": "optional", "staging": "optional", "prod": "optional" },
      "notes": "Defaults to info."
    },
    "NOTIFICATIONS_MODE": {
      "supabase": { "dev": "optional", "staging": "optional", "prod": "optional" },
      "notes": "Defaults to simulation."
    },
    "OCR_MIN_SCORE_APPLY": {
      "supabase": { "dev": "optional", "staging": "optional", "prod": "optional" },
      "notes": "Defaults to 0.70."
    },
    "REQUIRE_ORIGIN": {
      "supabase": { "dev": "optional", "staging": "optional", "prod": "optional" },
      "notes": "Defaults to true."
    },
    "SCRAPER_READ_MODE": {
      "supabase": { "dev": "optional", "staging": "optional", "prod": "optional" },
      "notes": "Defaults to anon."
    },
    "SENDGRID_API_KEY": {
      "supabase": { "dev": "optional", "staging": "optional", "prod": "optional" },
      "notes": "Feature-gated by real notifications and email channel enablement."
    },
    "SLACK_WEBHOOK_URL": {
      "supabase": { "dev": "optional", "staging": "optional", "prod": "optional" },
      "notes": "Optional Slack channel."
    },
    "SMTP_FROM": {
      "supabase": { "dev": "optional", "staging": "optional", "prod": "optional" },
      "notes": "Optional when email notifications stay disabled or simulated."
    },
    "SMTP_HOST": {
      "supabase": { "dev": "optional", "staging": "optional", "prod": "optional" },
      "notes": "Optional when email notifications stay disabled or simulated."
    },
    "SMTP_PASS": {
      "supabase": { "dev": "optional", "staging": "optional", "prod": "optional" },
      "notes": "Optional when email notifications stay disabled or simulated."
    },
    "SMTP_PORT": {
      "supabase": { "dev": "optional", "staging": "optional", "prod": "optional" },
      "notes": "Optional when email notifications stay disabled or simulated."
    },
    "SMTP_USER": {
      "supabase": { "dev": "optional", "staging": "optional", "prod": "optional" },
      "notes": "Optional when email notifications stay disabled or simulated."
    },
    "SUPABASE_ANON_KEY": {
      "supabase": { "dev": "required", "staging": "required", "prod": "required" },
      "notes": "Required by Edge Functions that proxy anon reads or validate auth context."
    },
    "SUPABASE_SERVICE_ROLE_KEY": {
      "supabase": { "dev": "required", "staging": "required", "prod": "required" },
      "notes": "Required by internal writes, cron jobs and admin operations."
    },
    "SUPABASE_URL": {
      "supabase": { "dev": "required", "staging": "required", "prod": "required" },
      "notes": "Required by every Edge Function that calls Supabase REST or creates clients."
    },
    "TEST_ENVIRONMENT": {
      "supabase": { "dev": "optional", "staging": "optional", "prod": "optional" },
      "notes": "Only used by cron-testing-suite."
    },
    "TWILIO_ACCOUNT_SID": {
      "supabase": { "dev": "optional", "staging": "optional", "prod": "optional" },
      "notes": "Optional SMS channel."
    },
    "TWILIO_AUTH_TOKEN": {
      "supabase": { "dev": "optional", "staging": "optional", "prod": "optional" },
      "notes": "Optional SMS channel."
    },
    "TWILIO_FROM_NUMBER": {
      "supabase": { "dev": "optional", "staging": "optional", "prod": "optional" },
      "notes": "Optional SMS channel."
    },
    "WEBHOOK_URL": {
      "supabase": { "dev": "optional", "staging": "optional", "prod": "optional" },
      "notes": "Optional generic webhook channel."
    }
  }
}
