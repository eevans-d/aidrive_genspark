# Configuración de Supabase
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key-aqui

# Configuración del API Gateway (Edge Functions)
# En desarrollo local: http://localhost:54321/functions/v1/api-minimarket
# En producción: la URL de tu proyecto Supabase + /functions/v1/api-minimarket
VITE_API_GATEWAY_URL=/api-minimarket

# AI Assistant URL (optional — defaults to VITE_SUPABASE_URL/functions/v1/api-assistant)
# En desarrollo local: http://localhost:54321/functions/v1/api-assistant
# VITE_API_ASSISTANT_URL=

# Mocks (NEVER enable in production — the app will throw on startup)
# VITE_USE_MOCKS=true

# Sentry DSN (optional — error tracking in production)
# VITE_SENTRY_DSN=
